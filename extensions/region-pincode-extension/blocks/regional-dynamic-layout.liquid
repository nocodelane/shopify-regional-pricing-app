{% schema %}
{
  "name": "Regional Dynamic Layout",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Admin Block Name (Optional)",
      "info": "Use this to name the block in the sidebar."
    },
    {
      "type": "paragraph",
      "content": "This block allows you to design and assign complex, multi-banner regional layouts directly from the Regional Pricing App Dashboard, saving you from adding dozens of native blocks here."
    }
  ]
}
{% endschema %}

<style>
  .dynamic-layout-container-{{ block.id }} {
    width: 100%;
    margin: 0;
    padding: 0;
    transition: opacity 0.3s ease-in-out;
  }
  .dynamic-layout-loader {
    display: none; /* We don't use giant skeletons anymore to avoid whitespace bugs */
  }
  .dynamic-banner-rendered {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.06);
    display: block;
    text-decoration: none;
  }
  .dynamic-banner-rendered img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .dynamic-banner-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    padding: 30px;
    z-index: 2;
  }
  .dynamic-banner-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none;
    z-index: 1;
  }
  .dynamic-banner-overlay h2 {
    color: inherit;
    margin: 0 0 10px 0;
    font-weight: 700;
  }
  .dynamic-banner-overlay p {
    margin: 0 0 20px 0;
    opacity: 0.9;
  }
  .dynamic-banner-btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 30px;
    font-weight: bold;
    font-size: 1rem;
    transition: opacity 0.2s, background-color 0.2s;
  }
</style>

<div id="dynamic-region-hub-{{ block.id }}" class="dynamic-layout-container-{{ block.id }}">
</div>

<script>
(function() {
    const blockId = "{{ block.id }}";
    const container = document.getElementById('dynamic-region-hub-' + blockId);

    function getCookie(name) {
        const nameEQ = name + "=";
        const ca = document.cookie.split(';');
        for(let i=0;i < ca.length;i++) {
            let c = ca[i];
            while (c.charAt(0)==' ') c = c.substring(1,c.length);
            if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length,c.length);
        }
        return null;
    }

    const DynamicRenderer = {
        banner: (settings) => {
            const dr = settings.desktopAspectRatio || '2.5';
            const mr = settings.mobileAspectRatio || dr;
            const dh = settings.desktopHeight || 'adapt';
            const mh = settings.mobileHeight || 'adapt';
            const align = settings.alignment || 'center';
            const textColor = settings.textColor || '#ffffff';
            const overlayOpacity = settings.overlayOpacity || '40';
            const bgColor = settings.overlayColor || '#000000';
            const fit = settings.imageFit || 'cover';
            
            const btnBg = settings.buttonBg || '#ffffff';
            const btnText = settings.buttonTextColor || '#000000';
            const btnStyle = settings.buttonStyle || 'solid';
            
            const btnHtml = btnStyle === 'solid' 
                ? `background-color: ${btnBg}; color: ${btnText}; border: 2px solid ${btnBg};` 
                : `background-color: transparent; color: ${btnBg}; border: 2px solid ${btnBg};`;

            const inlineStyle = `
                aspect-ratio: ${mr};
                ${mh !== 'adapt' ? `height: ${mh};` : ''}
                background: ${settings.backgroundColor || 'transparent'};
            `;
            const desktopStyle = `
                @media (min-width: 768px) {
                    #banner-dyn-${blockId} {
                        aspect-ratio: ${dr} !important;
                        ${dh !== 'adapt' ? `height: ${dh} !important;` : ''}
                    }
                }
            `;

            return `
                <style>${desktopStyle}</style>
                <a href="${settings.buttonLink || '#'}" id="banner-dyn-${blockId}" class="dynamic-banner-rendered" style="${inlineStyle}">
                    <picture style="display:block; height:100%; width:100%;">
                        ${settings.mobileImageUrl ? `<source media="(max-width: 767px)" srcset="${settings.mobileImageUrl}">` : ''}
                        <img src="${settings.imageUrl || 'https://placehold.co/1200x470?text=Offer'}" style="object-fit: ${fit};" />
                    </picture>
                    <div class="dynamic-banner-bg" style="background: ${bgColor}; opacity: ${parseInt(overlayOpacity)/100};"></div>
                    <div class="dynamic-banner-overlay" style="justify-content: ${align}; align-items: ${align}; text-align: center; color: ${textColor};">
                        ${settings.title ? `<h2>${settings.title}</h2>` : ''}
                        ${settings.subtitle ? `<p>${settings.subtitle}</p>` : ''}
                        ${settings.buttonText ? `<div style="margin-top:10px;"><span class="dynamic-banner-btn" style="${btnHtml}">${settings.buttonText}</span></div>` : ''}
                    </div>
                </a>
            `;
        },
        rich_text: (settings) => `
            <div style="margin-bottom:20px; padding:40px 20px; background:${settings.backgroundColor || '#f4f4f4'}; color:${settings.textColor || '#1a1a1a'}; border-radius:12px; text-align:${settings.alignment || 'center'}; max-width: 800px; margin: 0 auto 20px auto;">
                ${settings.title ? `<h2 style="margin-bottom:15px; font-weight:700;">${settings.title}</h2>` : ''}
                ${settings.content ? `<div style="font-size:1.1rem; opacity:0.9; line-height:1.6;">${settings.content}</div>` : ''}
            </div>`,
        counter: (settings) => {
            const end = new Date(settings.endDate || Date.now() + 86400000).getTime();
            const id = 'timer-' + Math.random().toString(36).substr(2, 9);
            const color = settings.primaryColor || '#000000';
            const bg = settings.backgroundColor || '#ffffff';
            
            setTimeout(() => {
                const clock = document.getElementById(id); if(!clock) return;
                const update = () => {
                    const now = new Date().getTime();
                    const diff = end - now;
                    if(diff <= 0) { clock.innerHTML = "EXPIRES"; return; }
                    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
                    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    const s = Math.floor((diff % (1000 * 60)) / 1000);
                    clock.querySelector('.d').innerText = d; 
                    clock.querySelector('.h').innerText = h.toString().padStart(2, '0');
                    clock.querySelector('.m').innerText = m.toString().padStart(2, '0');
                    clock.querySelector('.s').innerText = s.toString().padStart(2, '0');
                };
                update(); setInterval(update, 1000);
            }, 100);

            return `
                <div class="dynamic-timer-card" style="background: ${bg}; border: 1px solid #eee; border-radius: 12px; padding: 30px; margin-bottom: 20px; text-align: center;">
                    ${settings.title ? `<h3 style="margin: 0 0 15px 0; font-weight: 700; color:${color};">${settings.title}</h3>` : ''}
                    <div id="${id}" class="dynamic-clock" style="display: flex; gap: 15px; justify-content: center; font-weight: 800; color: ${color};">
                        <div class="unit"> <span class="d">0</span> <small style="display:block; font-size:10px; opacity:0.6; font-weight:400;">DAYS</small> </div>
                        <div class="unit"> <span class="h">00</span> <small style="display:block; font-size:10px; opacity:0.6; font-weight:400;">HRS</small> </div>
                        <div class="unit"> <span class="m">00</span> <small style="display:block; font-size:10px; opacity:0.6; font-weight:400;">MINS</small> </div>
                        <div class="unit"> <span class="s">00</span> <small style="display:block; font-size:10px; opacity:0.6; font-weight:400;">SECS</small> </div>
                    </div>
                </div>
            `;
        },
        products: (settings) => {
            const products = settings.products || [];
            if (products.length === 0) return '';
            return `
                <div style="margin-bottom: 30px;">
                    ${settings.title ? `<h2 style="margin-bottom: 20px; font-weight: 700;">${settings.title}</h2>` : ''}
                    <div class="dynamic-product-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 20px;">
                        ${products.map(p => `
                            <a href="/products/${p.handle}" class="dynamic-product-card" style="text-decoration: none; color: inherit;">
                                <div style="aspect-ratio: 1; overflow: hidden; border-radius: 8px; background: #f4f4f4; margin-bottom: 10px;">
                                    <img src="${p.imageUrl || 'https://placehold.co/400x400'}" style="width: 100%; height: 100%; object-fit: cover;" />
                                </div>
                                <div style="font-weight: 600; font-size: 14px; margin-bottom: 4px;">${p.title}</div>
                                <div style="opacity: 0.7; font-size: 14px;">${p.price || ''}</div>
                            </a>
                        `).join('')}
                    </div>
                </div>
            `;
        },
        custom_liquid: (settings) => {
            return `<div class="dynamic-custom-liquid">${settings.code || ''}</div>`;
        },
        pincode_widget: (settings) => {
            const pincode = localStorage.getItem("lastCheckedPincode") || "--";
            const style = settings.style || 'standard';
            const fontSize = settings.fontSize || '14px';
            const iconColor = settings.iconColor || '#000000';
            const message = settings.message || 'Regional Delivery';

            return `
                <div class="pincode-widget-container style-${style}" style="--widget-font-size: ${fontSize}; --widget-text-color: ${iconColor};" data-open-pincode-modal>
                    <div class="pincode-widget-message">${message}</div>
                    <div class="pincode-widget-details">
                        <span>${pincode}</span>
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="${iconColor}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    </div>
                </div>
            `;
        }
    };

    const init = async () => {
        const regionId = localStorage.getItem("regionId") || getCookie("regionId");
        if (!regionId || !container) return;

        const shop = "{{ shop.permanent_domain }}" || (window.Shopify && window.Shopify.shop) || "";
        try {
            const res = await fetch(`/apps/regional-sync-api/api/region-config?region=${regionId}&shop=${shop}`);
            if (!res.ok) return;
            const data = await res.json();
            const sections = data.homepage?.sections || [];

            if (sections.length > 0) {
                let html = "";
                sections.forEach(s => {
                    const render = DynamicRenderer[s.type];
                    if (render) html += render(s.settings);
                });
                
                container.style.opacity = "0";
                setTimeout(() => {
                    container.innerHTML = html;
                    container.style.opacity = "1";
                }, 50);
            }
        } catch (e) {
            console.error("Dynamic Hub Error:", e);
        }
    };

    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
})();
</script>
