{% schema %}
{
  "name": "Regional Dynamic Layout",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Admin Block Name (Optional)",
      "info": "Use this to name the block in the sidebar."
    },
    {
      "type": "paragraph",
      "content": "This block allows you to design and assign complex, multi-banner regional layouts directly from the Regional Pricing App Dashboard, saving you from adding dozens of native blocks here."
    }
  ]
}
{% endschema %}

<style>
  .dynamic-layout-container-{{ block.id }} {
    width: 100%;
    margin: 0;
    padding: 0;
    transition: opacity 0.3s ease-in-out;
  }
  .dynamic-layout-loader {
    display: none; /* We don't use giant skeletons anymore to avoid whitespace bugs */
  }
  .dynamic-banner-rendered {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.06);
    display: block;
    text-decoration: none;
  }
  .dynamic-banner-rendered img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .dynamic-banner-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    padding: 30px;
    z-index: 2;
  }
  .dynamic-banner-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none;
    z-index: 1;
  }
  .dynamic-banner-overlay h2 {
    color: inherit;
    margin: 0 0 10px 0;
    font-weight: 700;
  }
  .dynamic-banner-overlay p {
    margin: 0 0 20px 0;
    opacity: 0.9;
  }
  .dynamic-banner-btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 30px;
    font-weight: bold;
    font-size: 1rem;
    transition: opacity 0.2s, background-color 0.2s;
  }
</style>

<div id="dynamic-region-hub-{{ block.id }}" class="dynamic-layout-container-{{ block.id }}">
</div>

<script>
(function() {
    const blockId = "{{ block.id }}";
    const container = document.getElementById('dynamic-region-hub-' + blockId);

    function getCookie(name) {
        const nameEQ = name + "=";
        const ca = document.cookie.split(';');
        for(let i=0;i < ca.length;i++) {
            let c = ca[i];
            while (c.charAt(0)==' ') c = c.substring(1,c.length);
            if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length,c.length);
        }
        return null;
    }

    const DynamicRenderer = {
        banner: (settings) => {
            const dr = settings.desktopAspectRatio || '2.5';
            const mr = settings.mobileAspectRatio || dr;
            const dh = settings.desktopHeight || 'adapt';
            const mh = settings.mobileHeight || 'adapt';
            const align = settings.alignment || 'center';
            const textColor = settings.textColor || '#ffffff';
            const overlayOpacity = settings.overlayOpacity || '40';
            const bgColor = settings.overlayColor || '#000000';
            
            const btnBg = settings.buttonBg || '#ffffff';
            const btnText = settings.buttonTextColor || '#000000';
            const btnStyle = settings.buttonStyle || 'solid';
            
            const btnHtml = btnStyle === 'solid' 
                ? `background-color: ${btnBg}; color: ${btnText}; border: 2px solid ${btnBg};` 
                : `background-color: transparent; color: ${btnBg}; border: 2px solid ${btnBg};`;

            const inlineStyle = `
                aspect-ratio: ${mr};
                ${mh !== 'adapt' ? `height: ${mh};` : ''}
            `;
            const desktopStyle = `
                @media (min-width: 768px) {
                    #banner-dyn-${blockId} {
                        aspect-ratio: ${dr} !important;
                        ${dh !== 'adapt' ? `height: ${dh} !important;` : ''}
                    }
                }
            `;

            return `
                <style>${desktopStyle}</style>
                <a href="${settings.buttonLink || '#'}" id="banner-dyn-${blockId}" class="dynamic-banner-rendered" style="${inlineStyle}">
                    <picture style="display:block; height:100%; width:100%;">
                        ${settings.mobileImageUrl ? `<source media="(max-width: 767px)" srcset="${settings.mobileImageUrl}">` : ''}
                        <img src="${settings.imageUrl || 'https://placehold.co/1200x470?text=Offer'}" />
                    </picture>
                    <div class="dynamic-banner-bg" style="background: ${bgColor}; opacity: ${parseInt(overlayOpacity)/100};"></div>
                    <div class="dynamic-banner-overlay" style="justify-content: ${align}; align-items: ${align}; text-align: center; color: ${textColor};">
                        ${settings.title ? `<h2>${settings.title}</h2>` : ''}
                        ${settings.subtitle ? `<p>${settings.subtitle}</p>` : ''}
                        ${settings.buttonText ? `<div style="margin-top:10px;"><span class="dynamic-banner-btn" style="${btnHtml}">${settings.buttonText}</span></div>` : ''}
                    </div>
                </a>
            `;
        },
        rich_text: (settings) => `
            <div style="margin-bottom:20px; padding:40px 20px; background:${settings.backgroundColor || '#f4f4f4'}; color:${settings.textColor || '#1a1a1a'}; border-radius:12px; text-align:${settings.alignment || 'center'}; max-width: 800px; margin: 0 auto 20px auto;">
                ${settings.title ? `<h2 style="margin-bottom:15px; font-weight:700;">${settings.title}</h2>` : ''}
                ${settings.content ? `<div style="font-size:1.1rem; opacity:0.9; line-height:1.6;">${settings.content}</div>` : ''}
            </div>`
    };

    const init = async () => {
        const regionId = localStorage.getItem("regionId") || getCookie("regionId");
        if (!regionId || !container) return;

        const shop = "{{ shop.permanent_domain }}" || (window.Shopify && window.Shopify.shop) || "";
        try {
            const res = await fetch(`/apps/regional-sync-api/api/region-config?region=${regionId}&shop=${shop}`);
            if (!res.ok) return;
            const data = await res.json();
            const sections = data.homepage?.sections || [];

            if (sections.length > 0) {
                let html = "";
                sections.forEach(s => {
                    const render = DynamicRenderer[s.type];
                    if (render) html += render(s.settings);
                });
                
                container.style.opacity = "0";
                setTimeout(() => {
                    container.innerHTML = html;
                    container.style.opacity = "1";
                }, 50);
            }
        } catch (e) {
            console.error("Dynamic Hub Error:", e);
        }
    };

    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
})();
</script>
