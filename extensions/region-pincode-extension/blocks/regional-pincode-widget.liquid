<div 
  class="regional-pincode-widget-block" 
  data-component-id="{{ block.settings.component_id | escape }}"
  data-alignment="{{ block.settings.alignment }}"
  style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px; --widget-font-size: {{ block.settings.font_size }}px; --widget-icon-color: {{ block.settings.icon_color }}; --widget-text-color: {{ block.settings.text_color }};"
>
  <div class="regional-widget-content">
    {% if block.settings.component_id == blank %}
       <div class="pincode-widget-container style-{{ block.settings.universal_style }}" data-open-pincode-modal style="color: {{ block.settings.text_color }};">
          <div class="pincode-widget-message">{{ block.settings.universal_message }}</div>
          <div class="pincode-widget-details">
              <span class="pincode-display">--</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: {{ block.settings.icon_color }};"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
          </div>
       </div>
    {% else %}
       <div class="regional-widget-loading" style="min-height: 40px; opacity: 0.5; display: flex; align-items: center; justify-content: {{ block.settings.alignment }};">
          Loading localized message...
       </div>
    {% endif %}
  </div>
</div>

<style>
  .regional-pincode-widget-block { width: 100%; display: flex; }
  .regional-pincode-widget-block[data-alignment="left"] { justify-content: flex-start; }
  .regional-pincode-widget-block[data-alignment="center"] { justify-content: center; }
  .regional-pincode-widget-block[data-alignment="right"] { justify-content: flex-end; }
  
  .pincode-widget-container {
    display: flex;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 4px;
    border-radius: 4px;
    line-height: 1.2;
    font-size: var(--widget-font-size, 14px);
  }
  
  .pincode-widget-container:hover { opacity: 0.8; background: rgba(0,0,0,0.03); }
  
  .pincode-widget-container.style-minimal { flex-direction: row; align-items: center; gap: 8px; }
  .pincode-widget-container.style-minimal .pincode-widget-message { display: none; }
  
  .pincode-widget-container.style-pill {
    background: #f8f8f8;
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid #eee;
    flex-direction: row;
    align-items: center;
    gap: 10px;
  }
  
  .pincode-widget-message { font-weight: 500; }
  .pincode-widget-details {
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 700;
  }
</style>

{% schema %}
{
  "name": "Regional Pincode Widget",
  "target": "section",
  "class": "regional-pincode-widget-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Universal Mode",
      "info": "Use this for a quick, global widget. Leave Component ID blank."
    },
    {
      "type": "text",
      "id": "universal_message",
      "label": "Universal Message",
      "default": "Delivering to",
      "placeholder": "e.g. Ships to"
    },
    {
      "type": "select",
      "id": "universal_style",
      "label": "Widget Style",
      "options": [
        { "value": "standard", "label": "Stack (Standard)" },
        { "value": "minimal", "label": "Inline (Minimal)" },
        { "value": "pill", "label": "Pill Design" }
      ],
      "default": "standard"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Edit Icon Color",
      "default": "#008060"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Advanced: Regional Sync"
    },
    {
      "type": "text",
      "id": "component_id",
      "label": "Component ID (Optional)",
      "info": "Enter ID from App Dashboard to enable different messages for different cities."
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    }
  ]
}
{% endschema %}
