{% schema %}
{
  "name": "Regional Rich Text",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Admin Block Name (Optional)",
      "info": "Use this to name the block in the sidebar (e.g. 'Delhi Announcement'). It will not display on the store."
    },
    {
      "type": "text",
      "id": "target_region",
      "label": "Show only for Region",
      "info": "Enter Region Name (e.g. 'India'). Leave blank to show everywhere."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Regional Announcement"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>This is a custom message for customers in this specific region.</p>"
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Text Size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Styling & Colors"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Border Width",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Border Radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content Max Width",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_x",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 30
    },
    {
      "type": "range",
      "id": "margin_y",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical Margin (Spacing)",
      "default": 20
    }
  ]
}
{% endschema %}

<div 
  class="regional-richtext-{{ block.id }}" 
  data-target-region="{{ block.settings.target_region | escape }}"
>
  <style>
    .regional-richtext-{{ block.id }} {
      background-color: {{ block.settings.bg_color }};
      color: {{ block.settings.text_color }};
      padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
      margin: {{ block.settings.margin_y }}px auto;
      text-align: {{ block.settings.alignment }};
      border-radius: {{ block.settings.border_radius }}px;
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
      max-width: {{ block.settings.max_width }}px;
    }
    .regional-richtext-{{ block.id }} h2 {
      margin: 0 0 15px 0;
      color: inherit;
      font-weight: 700;
      {% if block.settings.heading_size == 'small' %}
        font-size: 1.5rem;
      {% elsif block.settings.heading_size == 'medium' %}
        font-size: 2rem;
      {% else %}
        font-size: 2.5rem;
      {% endif %}
    }
    .regional-richtext-{{ block.id }} .rte {
      opacity: 0.9;
      line-height: 1.6;
      {% if block.settings.text_size == 'small' %}
        font-size: 0.9rem;
      {% elsif block.settings.text_size == 'medium' %}
        font-size: 1.1rem;
      {% else %}
        font-size: 1.3rem;
      {% endif %}
    }
    .regional-richtext-{{ block.id }} .rte p:last-child {
      margin-bottom: 0;
    }
    .regional-richtext-btn-{{ block.id }} {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 28px;
      border-radius: 30px;
      font-weight: bold;
      font-size: 1rem;
      text-decoration: none;
      transition: opacity 0.2s, background-color 0.2s;
      
      {% if block.settings.button_style == 'solid' %}
        background-color: {{ block.settings.button_bg }};
        color: {{ block.settings.button_text_color }};
        border: 2px solid {{ block.settings.button_bg }};
      {% elsif block.settings.button_style == 'outline' %}
        background-color: transparent;
        color: {{ block.settings.button_bg }};
        border: 2px solid {{ block.settings.button_bg }};
      {% endif %}
    }
    .regional-richtext-btn-{{ block.id }}:hover {
      opacity: 0.8;
    }
  </style>

  {% if block.settings.heading != blank %}
    <h2>{{ block.settings.heading | escape }}</h2>
  {% endif %}
  
  {% if block.settings.content != blank %}
    <div class="rte">
      {{ block.settings.content }}
    </div>
  {% endif %}
  
  {% if block.settings.button_text != blank %}
    <a href="{{ block.settings.button_link | default: '#' }}" class="regional-richtext-btn-{{ block.id }}">
      {{ block.settings.button_text | escape }}
    </a>
  {% endif %}
</div>
