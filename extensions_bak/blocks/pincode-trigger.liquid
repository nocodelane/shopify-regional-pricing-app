<div class="pincode-trigger-wrapper" style="text-align: {{ block.settings.alignment }}; margin: 15px 0;">
    <button 
        data-open-pincode-modal 
        class="pincode-trigger-btn {{ block.settings.button_style }}"
        style="
            cursor: pointer;
            padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
            font-size: {{ block.settings.font_size }}px;
            {% if block.settings.full_width %}width: 100%;{% endif %}
        "
    >
        {{ block.settings.label }}
    </button>
</div>

<style>
.pincode-trigger-btn {
    transition: all 0.2s;
    border: none;
    border-radius: 4px;
}
.pincode-trigger-btn.primary {
    background: #000;
    color: #fff;
}
.pincode-trigger-btn.secondary {
    background: transparent;
    border: 1px solid #000;
    color: #000;
}
.pincode-trigger-btn.link {
    background: transparent;
    color: #000;
    text-decoration: underline;
    padding: 0 !important;
}
.pincode-trigger-btn:hover {
    opacity: 0.8;
}
</style>

{% schema %}
{
  "name": "Pincode Selector Trigger",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Button Label",
      "default": "Check Availability / Change Pincode"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "primary", "label": "Primary Button" },
        { "value": "secondary", "label": "Secondary Button" },
        { "value": "link", "label": "Text Link" }
      ],
      "default": "primary"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
        "type": "range",
        "id": "padding_x",
        "label": "Horizontal Padding",
        "min": 0,
        "max": 50,
        "step": 5,
        "default": 20,
        "unit": "px"
    },
    {
        "type": "range",
        "id": "padding_y",
        "label": "Vertical Padding",
        "min": 0,
        "max": 30,
        "step": 2,
        "default": 10,
        "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Stretch to Full Width",
      "default": false
    }
  ]
}
{% endschema %}
