{% schema %}
{
  "name": "Regional Banner",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Admin Block Name (Optional)",
      "info": "Use this to name the block in the sidebar (e.g. 'Delhi Banner'). It will not display on the store."
    },
    {
      "type": "text",
      "id": "target_region",
      "label": "Show only for Region",
      "info": "Enter Region Name (e.g. 'India'). Leave blank to show everywhere. Supports partial matches like 'US, Canada'."
    },
    {
      "type": "header",
      "content": "Image & Layout"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (optional)"
    },
    {
      "type": "select",
      "id": "layout_width",
      "label": "Layout Width",
      "options": [
        { "value": "full_width", "label": "Full Width" },
        { "value": "boxed", "label": "Boxed (Container)" }
      ],
      "default": "boxed"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop Height",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "adapt"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile Height",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "adapt"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Border Radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Exclusive Regional Offer"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Special prices available now in your area."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View Offer"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button Style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Colors & Overlays"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Positioning"
    },
    {
        "type": "select",
        "id": "alignment",
        "label": "Content Box Alignment",
        "options": [
          { "value": "flex-start", "label": "Top / Left" },
          { "value": "center", "label": "Center" },
          { "value": "flex-end", "label": "Bottom / Right" }
        ],
        "default": "center"
    },
    {
        "type": "select",
        "id": "text_alignment",
        "label": "Text Alignment",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ],
        "default": "center"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 20
    }
  ]
}
{% endschema %}

<div 
  class="regional-banner-block {% if block.settings.layout_width == 'full_width' %}regional-full-width{% endif %}" 
  data-target-region="{{ block.settings.target_region | escape }}"
>
  {% assign desktop_aspect = block.settings.desktop_image.aspect_ratio | default: 2.5 %}
  {% assign mobile_aspect = block.settings.mobile_image.aspect_ratio | default: desktop_aspect %}
  
  <style>
    .regional-banner-block.regional-full-width {
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-right: calc(-50vw + 50%);
      max-width: 100vw;
    }
    
    .regional-banner-wrapper-{{ block.id }} {
      position: relative;
      width: 100%;
      border-radius: {% if block.settings.layout_width == 'full_width' %}0{% else %}{{ block.settings.border_radius }}px{% endif %};
      overflow: hidden;
      margin-top: {{ block.settings.margin_top }}px;
      margin-bottom: {{ block.settings.margin_bottom }}px;
      box-shadow: 0 8px 25px rgba(0,0,0,0.06);
      display: block;
      text-decoration: none;
      
      {% if block.settings.mobile_height == 'adapt' %}
        aspect-ratio: {{ mobile_aspect }};
      {% elsif block.settings.mobile_height == 'small' %}
        height: 250px;
      {% elsif block.settings.mobile_height == 'medium' %}
        height: 350px;
      {% elsif block.settings.mobile_height == 'large' %}
        height: 450px;
      {% endif %}
    }
    
    .regional-banner-wrapper-{{ block.id }} img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .regional-banner-wrapper-{{ block.id }} .mobile-img {
       display: block;
    }
    .regional-banner-wrapper-{{ block.id }} .desktop-img {
       display: none;
    }
    .regional-banner-bg-{{ block.id }} {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: {{ block.settings.bg_color }};
      opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
      pointer-events: none;
      z-index: 1;
    }
    .regional-banner-content-{{ block.id }} {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      display: flex;
      flex-direction: column;
      justify-content: {{ block.settings.alignment }};
      align-items: {{ block.settings.alignment }};
      padding: 30px;
      text-align: {{ block.settings.text_alignment }};
      color: {{ block.settings.text_color }};
      z-index: 2;
    }
    
    .regional-banner-content-{{ block.id }} h2 {
      color: inherit;
      margin: 0 0 10px 0;
      font-weight: 700;
      {% if block.settings.heading_size == 'small' %}
        font-size: 1.8rem;
      {% elsif block.settings.heading_size == 'medium' %}
        font-size: 2.2rem;
      {% else %}
        font-size: 2.8rem;
      {% endif %}
    }
    
    .regional-banner-content-{{ block.id }} p {
      margin: 0 0 20px 0;
      opacity: 0.9;
      {% if block.settings.heading_size == 'small' %}
        font-size: 1rem;
      {% elsif block.settings.heading_size == 'medium' %}
        font-size: 1.2rem;
      {% else %}
        font-size: 1.4rem;
      {% endif %}
    }
    
    .regional-banner-btn-{{ block.id }} {
      display: inline-block;
      padding: 12px 28px;
      border-radius: 30px;
      font-weight: bold;
      font-size: 1rem;
      transition: opacity 0.2s, background-color 0.2s;
      
      {% if block.settings.button_style == 'solid' %}
        background-color: {{ block.settings.button_bg }};
        color: {{ block.settings.button_text_color }};
        border: 2px solid {{ block.settings.button_bg }};
      {% elsif block.settings.button_style == 'outline' %}
        background-color: transparent;
        color: {{ block.settings.button_bg }};
        border: 2px solid {{ block.settings.button_bg }};
      {% endif %}
    }
    .regional-banner-wrapper-{{ block.id }}:hover .regional-banner-btn-{{ block.id }} {
      opacity: 0.8;
    }
    
    @media (min-width: 768px) {
      .regional-banner-wrapper-{{ block.id }} {
        {% if block.settings.desktop_height == 'adapt' %}
          aspect-ratio: {{ desktop_aspect }};
          height: auto;
        {% elsif block.settings.desktop_height == 'small' %}
          height: 350px;
          aspect-ratio: auto;
        {% elsif block.settings.desktop_height == 'medium' %}
          height: 450px;
          aspect-ratio: auto;
        {% elsif block.settings.desktop_height == 'large' %}
          height: 600px;
          aspect-ratio: auto;
        {% endif %}
      }
      .regional-banner-wrapper-{{ block.id }} .mobile-img {
         display: none;
      }
      .regional-banner-wrapper-{{ block.id }} .desktop-img {
         display: block;
      }
      .regional-banner-content-{{ block.id }} {
         padding: 50px;
      }
      .regional-banner-content-{{ block.id }} h2 {
        {% if block.settings.heading_size == 'small' %}
          font-size: 2.4rem;
        {% elsif block.settings.heading_size == 'medium' %}
          font-size: 3rem;
        {% else %}
          font-size: 4rem;
        {% endif %}
      }
    }
  </style>

  <a href="{{ block.settings.button_link | default: '#' }}" class="regional-banner-wrapper-{{ block.id }}">
    {% if block.settings.mobile_image %}
      {{ block.settings.mobile_image | image_url: width: 800 | image_tag: class: 'mobile-img' }}
      {{ block.settings.desktop_image | image_url: width: 1400 | image_tag: class: 'desktop-img' }}
    {% elsif block.settings.desktop_image %}
      {{ block.settings.desktop_image | image_url: width: 1400 | image_tag }}
    {% else %}
      <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #e0e0e0; color: #a0a0a0;">
         {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {% endif %}

    <div class="regional-banner-bg-{{ block.id }}"></div>

    <div class="regional-banner-content-{{ block.id }}">
       {% if block.settings.heading != blank %}
         <h2>{{ block.settings.heading }}</h2>
       {% endif %}
       
       {% if block.settings.subheading != blank %}
         <p>{{ block.settings.subheading }}</p>
       {% endif %}

       {% if block.settings.button_text != blank %}
         <div style="margin-top: 10px;">
            <span class="regional-banner-btn-{{ block.id }}">
              {{ block.settings.button_text | escape }}
            </span>
         </div>
       {% endif %}
    </div>
  </a>
</div>
